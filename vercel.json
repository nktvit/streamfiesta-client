{
  "version": 2,
  "functions": {
    "api/suggestions.js": {
      "memory": 1024,
      "maxDuration": 15
    },
    "api/tmdb.js": {
      "memory": 1024,
      "maxDuration": 15
    }
  },
  "buildCommand": "npm run build",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
